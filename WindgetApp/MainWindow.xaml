<Window x:Class="WindgetApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Windget"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Loaded="Window_Loaded"
        Closing="Window_Closing"
        StateChanged="Window_StateChanged">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#D7242B33" />
        <SolidColorBrush x:Key="PanelInnerBrush" Color="#702B3440" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F8FAFC" />
        <SolidColorBrush x:Key="TextMutedBrush" Color="#B8C0CC" />
        <SolidColorBrush x:Key="AccentBrush" Color="#6EE7B7" />
        <SolidColorBrush x:Key="SecondAccentBrush" Color="#93C5FD" />
        <SolidColorBrush x:Key="LineBrush" Color="#45515F" />

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Pretendard, Segoe UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontFamily" Value="Pretendard, Segoe UI" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#263342" />
            <Setter Property="BorderBrush" Value="#3E4C5E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="FontFamily" Value="Pretendard, Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#202832" />
            <Setter Property="BorderBrush" Value="#3E4C5E" />
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontFamily" Value="Pretendard, Segoe UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#263342" />
            <Setter Property="BorderBrush" Value="#3E4C5E" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="FontFamily" Value="Pretendard, Segoe UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontFamily" Value="Pretendard, Segoe UI" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="WidgetTileToggle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#24303B" />
            <Setter Property="BorderBrush" Value="#425062" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Margin" Value="3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Tile"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IconPlate"
                                        Width="28"
                                        Height="28"
                                        CornerRadius="8"
                                        Background="#314052"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{TemplateBinding Tag}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="#2D3B49" />
                                <Setter TargetName="IconPlate" Property="Background" Value="#3D5368" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="#283F3A" />
                                <Setter TargetName="Tile" Property="BorderBrush" Value="#6EE7B7" />
                                <Setter TargetName="IconPlate" Property="Background" Value="#26745F" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Tile" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.98" ScaleY="0.98" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Tile" Property="RenderTransformOrigin" Value="0.5,0.5" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconActionButton" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Background" Value="#263342" />
            <Setter Property="BorderBrush" Value="#3E4C5E" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="Tile"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="9"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="28" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="IconPlate"
                                        Width="24"
                                        Height="24"
                                        CornerRadius="7"
                                        Background="#314052"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="{TemplateBinding Tag}"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="6,0,0,0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="#2D3B49" />
                                <Setter TargetName="IconPlate" Property="Background" Value="#3D5368" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Tile" Property="Background" Value="#283F3A" />
                                <Setter TargetName="Tile" Property="BorderBrush" Value="#6EE7B7" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CompactIconButton" TargetType="{x:Type Button}" BasedOn="{StaticResource IconActionButton}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="3" />
            <Setter Property="Content" Value="" />
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Height" Value="18" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="8" />
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="Background" Value="#DDE5E7EB" />
        </Style>

        <Style TargetType="ScrollViewer">
            <Setter Property="PanningMode" Value="VerticalOnly" />
            <Setter Property="CanContentScroll" Value="False" />
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Width" Value="7" />
            <Setter Property="MinWidth" Value="7" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageUpCommand}" Opacity="0" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Background="#75B8C0CC">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="{x:Type Thumb}">
                                                <Border Width="5"
                                                        Margin="1,2"
                                                        CornerRadius="3"
                                                        Background="{TemplateBinding Background}" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="{x:Static ScrollBar.PageDownCommand}" Opacity="0" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Canvas x:Name="WidgetCanvas" Background="{x:Null}">
        <Border x:Name="ControlWidget" Width="330" Height="350" MinWidth="280" MinHeight="280"
                Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1" CornerRadius="12" Padding="14" Canvas.Left="24" Canvas.Top="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid MouseLeftButtonDown="WidgetHeader_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Image Source="Assets/WindgetIcon.png" Width="42" Height="42" Stretch="Uniform"
                               VerticalAlignment="Center" Margin="0,0,10,0" />
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Windget" FontSize="19" FontWeight="SemiBold" />
                            <TextBlock x:Name="ClockText" Style="{StaticResource MutedText}" FontSize="12" />
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="Move" Style="{StaticResource MutedText}" VerticalAlignment="Center" />
                </Grid>

                <StackPanel Grid.Row="1" Margin="0,14,0,10">
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Global Opacity" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Slider x:Name="GlobalOpacitySlider" Grid.Column="1" Minimum="0.35" Maximum="1" Value="1"
                                ValueChanged="GlobalOpacitySlider_ValueChanged" />
                    </Grid>
                    <CheckBox x:Name="TopmostCheck" Content="Always On Top" IsChecked="True"
                              Checked="ControlSetting_Changed" Unchecked="ControlSetting_Changed" Margin="0,0,0,8" />
                    <CheckBox x:Name="StartupCheck" Content="Start With Windows"
                              Checked="ControlSetting_Changed" Unchecked="ControlSetting_Changed" Margin="0,0,0,10" />
                    <UniformGrid Columns="2" Rows="3">
                        <ToggleButton x:Name="ShowTodoCheck" Content="Memo" Tag="&#xE70F;" Style="{StaticResource WidgetTileToggle}" Checked="WidgetVisibility_Changed" Unchecked="WidgetVisibility_Changed" />
                        <ToggleButton x:Name="ShowSystemCheck" Content="System" Tag="&#xE9D9;" Style="{StaticResource WidgetTileToggle}" Checked="WidgetVisibility_Changed" Unchecked="WidgetVisibility_Changed" />
                        <ToggleButton x:Name="ShowCalendarCheck" Content="Calendar" Tag="&#xE787;" Style="{StaticResource WidgetTileToggle}" Checked="WidgetVisibility_Changed" Unchecked="WidgetVisibility_Changed" />
                        <ToggleButton x:Name="ShowFocusCheck" Content="Focus" Tag="&#xE916;" Style="{StaticResource WidgetTileToggle}" Checked="WidgetVisibility_Changed" Unchecked="WidgetVisibility_Changed" />
                        <ToggleButton x:Name="ShowLauncherCheck" Content="Launcher" Tag="&#xE8B7;" Style="{StaticResource WidgetTileToggle}" Checked="WidgetVisibility_Changed" Unchecked="WidgetVisibility_Changed" />
                        <ToggleButton x:Name="ShowSoundCheck" Content="Sound" Tag="&#xE995;" Style="{StaticResource WidgetTileToggle}" Checked="WidgetVisibility_Changed" Unchecked="WidgetVisibility_Changed" />
                    </UniformGrid>
                    <TextBlock Text="Headers Move. Corners Resize. Auto Layout Tidies The Desk." Style="{StaticResource MutedText}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,12,0,0" />
                </StackPanel>

                <StackPanel Grid.Row="2" Orientation="Horizontal">
                    <Button Content="Auto" Tag="&#xE8B3;" Style="{StaticResource IconActionButton}" Click="AutoLayout_Click" Margin="0,0,8,0" />
                    <Button Content="Save" Tag="&#xE74E;" Style="{StaticResource IconActionButton}" Click="SaveLayout_Click" Margin="0,0,8,0" />
                    <Button Content="Hide" Tag="&#xE921;" Style="{StaticResource IconActionButton}" Click="Minimize_Click" Margin="0,0,8,0" />
                    <Button Content="Exit" Tag="&#xE8BB;" Style="{StaticResource IconActionButton}" Click="Exit_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="TodoWidget" Width="430" Height="680" MinWidth="340" MinHeight="420"
                Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1" CornerRadius="12" Padding="16" Canvas.Left="24" Canvas.Top="380">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid MouseLeftButtonDown="WidgetHeader_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Memo" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="TaskCountText" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Tag="&#xE713;" Style="{StaticResource CompactIconButton}" ToolTip="Widget Settings"
                            Click="ToggleWidgetSettings_Click" />
                </Grid>
                <Border x:Name="TodoSettingsPanel" Grid.Row="1" Visibility="Collapsed" Background="{StaticResource PanelInnerBrush}"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Opacity" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Slider x:Name="TodoOpacitySlider" Grid.Column="1" Minimum="0.3" Maximum="1" Value="0.94"
                                ValueChanged="WidgetOpacity_ValueChanged" />
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="2" Margin="0,14,0,14" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TasksPanel" />
                </ScrollViewer>
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Title" Style="{StaticResource MutedText}" Margin="2,0,0,4" />
                    <TextBox x:Name="NewTaskTitleText" Grid.Row="1" MinHeight="36" ToolTip="Title" />
                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Content" Style="{StaticResource MutedText}" Margin="2,0,0,4" />
                            <TextBox x:Name="NewTaskContentText" MinHeight="38" AcceptsReturn="True"
                                     TextWrapping="Wrap" ToolTip="Content" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Add" Tag="&#xE710;" Style="{StaticResource IconActionButton}" Margin="8,18,0,0" Click="AddTask_Click" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="SystemWidget" Width="390" Height="560" MinWidth="330" MinHeight="440"
                Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1" CornerRadius="12" Padding="16" Canvas.Left="480" Canvas.Top="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid MouseLeftButtonDown="WidgetHeader_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="System" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="ResourceUpdatedText" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Tag="&#xE713;" Style="{StaticResource CompactIconButton}" ToolTip="Widget Settings"
                            Click="ToggleWidgetSettings_Click" />
                </Grid>
                <Border x:Name="SystemSettingsPanel" Grid.Row="1" Visibility="Collapsed" Background="{StaticResource PanelInnerBrush}"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Opacity" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Slider x:Name="SystemOpacitySlider" Grid.Column="1" Minimum="0.3" Maximum="1" Value="0.94"
                                ValueChanged="WidgetOpacity_ValueChanged" />
                    </Grid>
                </Border>
                <StackPanel Grid.Row="2" Margin="0,16,0,0">
                    <TextBlock Text="CPU" Style="{StaticResource MutedText}" />
                    <ProgressBar x:Name="CpuBar" Height="10" Maximum="100" Margin="0,6,0,4" />
                    <TextBlock x:Name="CpuText" FontSize="21" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Canvas x:Name="CpuGraphCanvas" Height="70" Background="{StaticResource PanelInnerBrush}" Margin="0,0,0,14">
                        <Polyline x:Name="CpuGraphLine" Stroke="{StaticResource AccentBrush}" StrokeThickness="2" />
                    </Canvas>
                    <TextBlock Text="Memory" Style="{StaticResource MutedText}" />
                    <ProgressBar x:Name="MemoryBar" Height="10" Maximum="100" Margin="0,6,0,4" />
                    <TextBlock x:Name="MemoryText" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Canvas x:Name="MemoryGraphCanvas" Height="70" Background="{StaticResource PanelInnerBrush}" Margin="0,0,0,14">
                        <Polyline x:Name="MemoryGraphLine" Stroke="{StaticResource SecondAccentBrush}" StrokeThickness="2" />
                    </Canvas>
                    <TextBlock Text="GPU" Style="{StaticResource MutedText}" />
                    <ProgressBar x:Name="GpuBar" Height="10" Maximum="100" Margin="0,6,0,4" />
                    <TextBlock x:Name="GpuText" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <Canvas x:Name="GpuGraphCanvas" Height="70" Background="{StaticResource PanelInnerBrush}" Margin="0,0,0,14">
                        <Polyline x:Name="GpuGraphLine" Stroke="#FBBF24" StrokeThickness="2" />
                    </Canvas>
                    <TextBlock Text="Network" Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="NetworkText" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,12" />
                    <TextBlock Text="App Memory" Style="{StaticResource MutedText}" />
                    <TextBlock x:Name="AppMemoryText" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="SoundWidget" Width="430" Height="520" MinWidth="360" MinHeight="380"
                Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1" CornerRadius="12" Padding="16" Canvas.Left="900" Canvas.Top="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid MouseLeftButtonDown="WidgetHeader_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Sound Mixer" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock x:Name="SoundUpdatedText" Style="{StaticResource MutedText}" Margin="0,3,0,0" />
                    </StackPanel>
                    <Button Grid.Column="1" Tag="&#xE713;" Style="{StaticResource CompactIconButton}" ToolTip="Widget Settings"
                            Click="ToggleWidgetSettings_Click" />
                </Grid>
                <Border x:Name="SoundSettingsPanel" Grid.Row="1" Visibility="Collapsed" Background="{StaticResource PanelInnerBrush}"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Opacity" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Slider x:Name="SoundOpacitySlider" Grid.Column="1" Minimum="0.3" Maximum="1" Value="0.94"
                                ValueChanged="WidgetOpacity_ValueChanged" />
                    </Grid>
                </Border>
                <Border Grid.Row="2" Background="{StaticResource PanelInnerBrush}" BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,14,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,6,0">
                            <TextBlock Text="Playback Device" Style="{StaticResource MutedText}" Margin="2,0,0,4" />
                            <Button x:Name="PlaybackDeviceButton" Tag="&#xE995;" Style="{StaticResource IconActionButton}"
                                    Click="AudioDeviceButton_Click" HorizontalContentAlignment="Left" MinHeight="34" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="6,0,0,0">
                            <TextBlock Text="Recording Device" Style="{StaticResource MutedText}" Margin="2,0,0,4" />
                            <Button x:Name="RecordingDeviceButton" Tag="&#xE720;" Style="{StaticResource IconActionButton}"
                                    Click="AudioDeviceButton_Click" HorizontalContentAlignment="Left" MinHeight="34" />
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Row="3" Background="{StaticResource PanelInnerBrush}" BorderBrush="{StaticResource LineBrush}"
                        BorderThickness="1" CornerRadius="10" Padding="10" Margin="0,14,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Master Volume" FontSize="15" FontWeight="SemiBold" />
                            <Slider x:Name="MasterVolumeSlider" Minimum="0" Maximum="100" ValueChanged="MasterVolume_ValueChanged"
                                    PreviewMouseLeftButtonDown="AudioVolumeSlider_DragStarted"
                                    PreviewMouseLeftButtonUp="AudioVolumeSlider_DragCompleted"
                                    LostMouseCapture="AudioVolumeSlider_DragCompleted"
                                    IsMoveToPointEnabled="True"
                                    Margin="0,8,0,0" />
                        </StackPanel>
                        <ToggleButton x:Name="MasterMuteButton" Grid.Column="1" Content="Mute" Tag="&#xE198;"
                                      Style="{StaticResource WidgetTileToggle}" MinWidth="88" Margin="10,16,0,0"
                                      Checked="MasterMute_Changed" Unchecked="MasterMute_Changed" />
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="AudioSessionsPanel" />
                </ScrollViewer>
            </Grid>
        </Border>

        <Border x:Name="CalendarWidget" Width="410" Height="660" MinWidth="360" MinHeight="460"
                Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1" CornerRadius="12" Padding="16" Canvas.Left="900" Canvas.Top="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="282" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid MouseLeftButtonDown="WidgetHeader_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Tag="&#xE76B;" Style="{StaticResource CompactIconButton}" Click="PreviousMonth_Click" />
                    <TextBlock x:Name="MonthText" Grid.Column="1" TextAlignment="Center" FontSize="18"
                               FontWeight="SemiBold" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Tag="&#xE76C;" Style="{StaticResource CompactIconButton}" Click="NextMonth_Click" />
                        <Button Tag="&#xE713;" Style="{StaticResource CompactIconButton}" ToolTip="Widget Settings"
                                Click="ToggleWidgetSettings_Click" Margin="8,0,0,0" />
                    </StackPanel>
                </Grid>
                <Border x:Name="CalendarSettingsPanel" Grid.Row="1" Visibility="Collapsed" Background="{StaticResource PanelInnerBrush}"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Opacity" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Slider x:Name="CalendarOpacitySlider" Grid.Column="1" Minimum="0.3" Maximum="1" Value="0.94"
                                ValueChanged="WidgetOpacity_ValueChanged" />
                    </Grid>
                </Border>
                <UniformGrid Grid.Row="2" Columns="7" Margin="0,16,0,8">
                    <TextBlock Text="Sun" Style="{StaticResource MutedText}" TextAlignment="Center" />
                    <TextBlock Text="Mon" Style="{StaticResource MutedText}" TextAlignment="Center" />
                    <TextBlock Text="Tue" Style="{StaticResource MutedText}" TextAlignment="Center" />
                    <TextBlock Text="Wed" Style="{StaticResource MutedText}" TextAlignment="Center" />
                    <TextBlock Text="Thu" Style="{StaticResource MutedText}" TextAlignment="Center" />
                    <TextBlock Text="Fri" Style="{StaticResource MutedText}" TextAlignment="Center" />
                    <TextBlock Text="Sat" Style="{StaticResource MutedText}" TextAlignment="Center" />
                </UniformGrid>
                <UniformGrid x:Name="CalendarGrid" Grid.Row="3" Columns="7" Rows="6" />
                <Grid Grid.Row="4" Margin="0,14,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="SelectedDateText" FontSize="16" FontWeight="SemiBold" />
                    <ScrollViewer Grid.Row="1" Margin="0,10,0,10" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="EventsPanel" />
                    </ScrollViewer>
                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Event Title" Style="{StaticResource MutedText}" Margin="2,0,0,4" />
                            <TextBox x:Name="NewEventText" MinHeight="38" KeyDown="NewEventText_KeyDown" />
                        </StackPanel>
                        <Button Grid.Column="1" Grid.RowSpan="3" Content="Add" Tag="&#xE710;" Style="{StaticResource IconActionButton}" Margin="8,18,0,0" Click="AddEvent_Click" />
                        <StackPanel Grid.Row="1" Margin="0,8,0,0">
                            <TextBlock Text="Location" Style="{StaticResource MutedText}" Margin="2,0,0,4" />
                            <TextBox x:Name="NewEventLocationText" MinHeight="34"
                                     ToolTip="Location" KeyDown="NewEventText_KeyDown" />
                        </StackPanel>
                        <Grid Grid.Row="2" Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Start Time" Style="{StaticResource MutedText}" Margin="2,0,0,4" />
                                <Button x:Name="NewEventStartButton" Content="None" Tag="&#xE823;" Style="{StaticResource IconActionButton}"
                                        MinHeight="34" ToolTip="Start Time" Click="EventTimeButton_Click" />
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="-" Style="{StaticResource MutedText}" VerticalAlignment="Bottom" Margin="8,0,8,8" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="End Time" Style="{StaticResource MutedText}" Margin="2,0,0,4" />
                                <Button x:Name="NewEventEndButton" Content="None" Tag="&#xE823;" Style="{StaticResource IconActionButton}"
                                        MinHeight="34" ToolTip="End Time" Click="EventTimeButton_Click" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="FocusWidget" Width="360" Height="390" MinWidth="320" MinHeight="340"
                Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1" CornerRadius="12" Padding="16" Canvas.Left="480" Canvas.Top="520">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid MouseLeftButtonDown="WidgetHeader_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="FocusTitleText" Text="Timer" FontSize="18" FontWeight="SemiBold" />
                    <Button Grid.Column="1" Tag="&#xE713;" Style="{StaticResource CompactIconButton}" ToolTip="Widget Settings"
                            Click="ToggleWidgetSettings_Click" />
                </Grid>
                <Border x:Name="FocusSettingsPanel" Grid.Row="1" Visibility="Collapsed" Background="{StaticResource PanelInnerBrush}"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,12,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Opacity" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Slider x:Name="FocusOpacitySlider" Grid.Column="1" Minimum="0.3" Maximum="1" Value="0.94"
                                ValueChanged="WidgetOpacity_ValueChanged" />
                    </Grid>
                </Border>
                <UniformGrid Grid.Row="2" Columns="2" Margin="0,14,0,10">
                    <ToggleButton x:Name="TimerModeButton" Content="Timer" Tag="&#xE916;" Style="{StaticResource WidgetTileToggle}"
                                  MinHeight="44" Checked="FocusMode_Checked" />
                    <ToggleButton x:Name="StopwatchModeButton" Content="Stopwatch" Tag="&#xE121;" Style="{StaticResource WidgetTileToggle}"
                                  MinHeight="44" Checked="FocusMode_Checked" />
                </UniformGrid>
                <StackPanel Grid.Row="3" VerticalAlignment="Center">
                    <TextBlock x:Name="FocusTimeText" Text="25:00" FontSize="48" FontWeight="SemiBold"
                               TextAlignment="Center" HorizontalAlignment="Center" />
                    <StackPanel x:Name="FocusMinutesPanel" HorizontalAlignment="Center" Margin="0,12,0,0">
                        <StackPanel>
                            <TextBlock Text="Duration" Style="{StaticResource MutedText}" TextAlignment="Center" Margin="0,0,0,4" />
                            <Button x:Name="FocusDurationButton" Content="00:25" Tag="&#xE121;" Style="{StaticResource IconActionButton}"
                                    Width="104" Click="FocusDurationButton_Click" />
                        </StackPanel>
                    </StackPanel>
                    <ToggleButton x:Name="FocusAlarmToggle" Content="Alarm" Tag="&#xE7ED;" Style="{StaticResource WidgetTileToggle}"
                                  HorizontalAlignment="Center" Margin="0,12,0,0"
                                  Checked="FocusAlarm_Changed" Unchecked="FocusAlarm_Changed" />
                </StackPanel>
                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button x:Name="FocusStartPauseButton" Content="Start" Tag="&#xE768;" Style="{StaticResource IconActionButton}" Click="FocusStartPause_Click" Margin="0,0,8,0" />
                    <Button Content="Reset" Tag="&#xE72C;" Style="{StaticResource IconActionButton}" Click="FocusReset_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="LauncherWidget" Width="380" Height="360" MinWidth="330" MinHeight="260"
                Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource LineBrush}"
                BorderThickness="1" CornerRadius="12" Padding="16" Canvas.Left="840" Canvas.Top="720"
                AllowDrop="True" DragOver="Launcher_DragOver" Drop="Launcher_Drop">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid MouseLeftButtonDown="WidgetHeader_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Quick Launcher" FontSize="18" FontWeight="SemiBold" />
                    <Button Grid.Column="1" Tag="&#xE713;" Style="{StaticResource CompactIconButton}" ToolTip="Widget Settings"
                            Click="ToggleWidgetSettings_Click" />
                </Grid>
                <Border x:Name="LauncherSettingsPanel" Grid.Row="1" Visibility="Collapsed" Background="{StaticResource PanelInnerBrush}"
                        BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="9" Padding="10" Margin="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Opacity" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,0,10,0" />
                        <Slider x:Name="LauncherOpacitySlider" Grid.Column="1" Minimum="0.3" Maximum="1" Value="0.94"
                                ValueChanged="WidgetOpacity_ValueChanged" />
                        <TextBlock Grid.Row="1" Text="View" Style="{StaticResource MutedText}" VerticalAlignment="Center" Margin="0,10,10,0" />
                        <ToggleButton x:Name="LauncherIconOnlyToggle" Grid.Row="1" Grid.Column="1" Content="Icon Only" Tag="&#xE8A5;"
                                      Style="{StaticResource WidgetTileToggle}" Margin="0,10,0,0"
                                      Checked="LauncherViewMode_Changed" Unchecked="LauncherViewMode_Changed" />
                    </Grid>
                </Border>
                <ScrollViewer Grid.Row="2" Margin="0,14,0,14" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="LauncherPanel" />
                </ScrollViewer>
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Drop Files, Folders, Or Shortcuts Into A Category." Style="{StaticResource MutedText}"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,8" />
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Category Name" Style="{StaticResource MutedText}" Margin="2,0,0,4" />
                            <TextBox x:Name="NewLauncherCategoryText" MinHeight="34" ToolTip="Category Name" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Add" Tag="&#xE710;" Style="{StaticResource IconActionButton}"
                                Margin="8,18,0,0" Click="AddLauncherCategory_Click" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border x:Name="VerticalAlignmentGuide" Width="2" Background="{StaticResource AccentBrush}"
                Opacity="0.9" Visibility="Collapsed" IsHitTestVisible="False" />
        <Border x:Name="HorizontalAlignmentGuide" Height="2" Background="{StaticResource AccentBrush}"
                Opacity="0.9" Visibility="Collapsed" IsHitTestVisible="False" />
    </Canvas>
</Window>
